{
  "name": "vertical-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:no-turbo": "next dev",
    "clean:install": "rm -rf node_modules package-lock.json && npm install",
    "dev:local": "cross-env NODE_ENV=development dotenv -e .env.local -- next dev",
    "dev:dev": "npm run dev:local",
    "dev:test": "cross-env NODE_ENV=test dotenv -e .env.test -- next dev",
    "dev:prod": "dotenv -e .env.production -- next dev",
    "compile": "tsc",
    "build:local": "dotenv -e .env.local -- next build",
    "build": "next build",
    "build:object-types": "node scripts/generate-object-types-json.mjs",
    "start": "node server.js",
    "start:prod": "cross-env NODE_ENV=production dotenv -e .env.production -- next start",
    "start:test": "cross-env NODE_ENV=test dotenv -e .env.test -- next start",
    "start:local": "cross-env NODE_ENV=local dotenv -e .env.local -- next start",
    "prod": "npm run build && npm run start:prod-1",
    "start:prod-1": "cross-env NODE_ENV=production next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "npx prettier --write .",
    "format:fix": "prettier --write --list-different .",
    "format:check": "prettier --check .",
    "format:diff": "prettier --list-different .",
    "lint-staged": "lint-staged",
    "eslint": "eslint .",
    "test": "jest",
    "prepare": "if [ \"$HUSKY\" != \"0\" ]; then husky; fi",
    "test:unit": "jest --watchAll --passWithNoTests",
    "test:unit:ci": "jest --ci --bail --passWithNoTests",
    "test:unit:coverage": "jest --coverage",
    "test:unit:coverage:ci": "jest --ci --bail --coverage --passWithNoTests",
    "test:unit:coverage:report": "jest --coverage --passWithNoTests --collectCoverageFrom='src/**/*.{js,jsx,ts,tsx}'",
    "test:unit:coverage:report:ci": "jest --coverage --passWithNoTests --collectCoverageFrom='src/**/*.{js,jsx,ts,tsx}'",
    "build:playwright": "cross-env NODE_ENV=e2e NEXT_PUBLIC_MSAL_REDIRECT_URI=http://localhost:3000 next build",
    "test:playwright": "playwright test",
    "test:playwright:ci": "playwright test --ci",
    "test:playwright:coverage": "playwright test --coverage",
    "test:playwright:report": "playwright test --reporter dot",
    "test:playwright:report:ci": "playwright test --reporter dot --ci",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:ui:ci": "playwright test --ui --ci",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@enterpriseaigroup/core": "*",
    "@enterpriseaigroup/demo": "*",
    "@eslint/eslintrc": "^3",
    "@hookform/resolvers": "^5.0.1",
    "@next/env": "^15.5.9",
    "@radix-ui/react-accordion": "^1.2.8",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-radio-group": "^1.3.6",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@tailwindcss/postcss": "^4.1.17",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/jsrsasign": "^10.5.15",
    "@types/node": "^20.17.30",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitest/browser": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1",
    "autoprefixer": "^10.4.21",
    "axios": "^1.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "cypress": "^14.2.1",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^10.1.1",
    "html-encoding-sniffer": "^4.0.0",
    "husky": "^9.1.7",
    "immer": "^10.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^26.1.0",
    "jsrsasign": "^11.1.0",
    "ldrs": "^1.0.2",
    "lint-staged": "^15.5.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.548.0",
    "marked": "^15.0.11",
    "nanoid": "^5.1.5",
    "next": "^15.5.16",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "next-transpile-modules": "^10.0.1",
    "npm": "^11.3.0",
    "pako": "^2.1.0",
    "path": "^0.12.7",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-haiku": "^2.2.0",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.5.0",
    "react-textarea-autosize": "^8.5.9",
    "reflect-metadata": "^0.2.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "start-server-and-test": "^2.0.11",
    "style-loader": "^4.0.0",
    "tailwind-merge": "^3.1.0",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwindcss": "^4.1.3",
    "tough-cookie": "^5.1.2",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "tsyringe": "^4.9.1",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.8.3",
    "use-sync-external-store": "^1.6.0",
    "uuid": "^11.1.0",
    "vitest": "^3.1.1",
    "wait-on": "^8.0.3",
    "zod": "^3.24.2",
    "zustand": "^5.0.3",
    "zustand-logger-middleware": "^1.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "playwright": "^1.57.0",
    "postcss-cli": "^11.0.1"
  }
}
