# =============================================================================
# App Identity
# =============================================================================
NEXT_PUBLIC_APP_NAME=my-vertical
APP_BASE_PATH=/my-vertical
# Mirrored as NEXT_PUBLIC_* so client-side code (SessionProvider basePath)
# can read it. APP_BASE_PATH alone is server-only. Keep these in sync.
NEXT_PUBLIC_APP_BASE_PATH=/my-vertical
# Default tenantId the platform SDK uses for client-side path construction
# when callers don't pass one. Without this, `useResources('Brand')` builds
# `/v3/resources//brand` (double slash) which Next.js 308-redirects, losing
# the tenant segment. The BFF still forces the canonical tenant via header,
# so this is purely for URL path shape.
NEXT_PUBLIC_EAI_TENANT_ID=

# =============================================================================
# Platform API
# =============================================================================
# PublicAPI gateway URL — static fallback for localhost, client-hosted, or
# bootstrap outage scenarios. Authenticated users can be re-targeted at runtime
# via /v3/session/resolve.
BASE_URL_PUBLIC_API=

# Bootstrap PublicAPI endpoint used to resolve the tenant's regional API host.
# This is the platform-owned bootstrap, not the final regional API target.
ROUTING_BOOTSTRAP_PUBLIC_API_URL=https://api.au.myenterprise.ai

# Product slug sent to PublicAPI when resolving session routing.
EAI_PRODUCT_SLUG=my-vertical

# =============================================================================
# Tenant & Workflow Configuration
# =============================================================================
# Comma-separated list of tenant keys (drives config/route.ts dynamic reading)
TENANT_KEYS=template

# For each tenant key, set TENANT_{KEY}_ID and WORKFLOW_{KEY}_ID
# Key must be UPPER_CASE with hyphens replaced by underscores
TENANT_TEMPLATE_ID=<configurator-tenant-record-id>
WORKFLOW_TEMPLATE_ID=<configurator-workflow-record-id>

# =============================================================================
# Microsoft Entra ID (CIAM)
# =============================================================================
# Register an app in your CIAM tenant with redirect URI matching APP_BASE_PATH:
#   http://localhost:3000{APP_BASE_PATH}/api/auth/callback/microsoft-entra-id
# (e.g. http://localhost:3000/my-vertical/api/auth/callback/microsoft-entra-id
#  when APP_BASE_PATH=/my-vertical, or .../api/auth/callback/... when empty)
# See https://eai-tools.github.io/vt-docs/docs/getting-started/quickstart for setup instructions

# CIAM tenant name (e.g., "eaidevmyentepriseai" from eaidevmyentepriseai.ciamlogin.com)
ENTRA_TENANT_NAME=""

# CIAM tenant ID (GUID)
ENTRA_TENANT_ID=""

# App registration client ID
ENTRA_CLIENT_ID=""

# App registration client secret (keep secure!)
ENTRA_CLIENT_SECRET=""

# OAuth scopes — include PublicAPI scope for client credentials if needed
# Example: "email offline_access openid profile api://your-api-app-id/.default"
ENTRA_SCOPES="email offline_access openid profile"

# =============================================================================
# Auth.js Configuration
# =============================================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth.js v5 + Next.js basePath: when APP_BASE_PATH is set, Auth.js needs
# AUTH_URL to include the full path (origin + basePath + /api/auth) so it
# generates correct callback URLs and the [...nextauth] route's request
# rewriter knows what prefix to restore. Leave unset if APP_BASE_PATH is
# empty (app mounted at host root). Upstream: nextauthjs/next-auth#9722.
AUTH_URL=http://localhost:3000/my-vertical/api/auth
AUTH_TRUST_HOST=true
